# Inner Child — Web App Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local — they contain secrets.

# API base URL (FastAPI backend)
IC_API_BASE_URL=http://localhost:8000

# Public-facing app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_PORTRAIT=false
NEXT_PUBLIC_ENABLE_CANVAS=false
