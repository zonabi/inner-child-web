# Inner Child — Web App Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local — they contain secrets.

# API base URL (FastAPI backend).
# NEXT_PUBLIC_ prefix makes it available in browser code.
NEXT_PUBLIC_IC_API_URL=http://localhost:8000

# Public-facing app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_PORTRAIT=false
NEXT_PUBLIC_ENABLE_CANVAS=true
